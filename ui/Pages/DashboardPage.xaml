<Page x:Class="ToolsCloud.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:res="clr-namespace:ToolsCloud.Resources"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="800">

            <Border x:Name="UpdateBanner"
                    Visibility="Collapsed"
                    Background="#332F7A2F"
                    BorderBrush="#FF6A9F42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <DockPanel>
                    <ui:Button Content="{res:Loc Dashboard_UpdateNow}"
                               Appearance="Success"
                               DockPanel.Dock="Right"
                               VerticalAlignment="Center"
                               Click="UpdateDll_Click" />
                    <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="{res:Loc Dashboard_UpdateAvailable}"
                                   FontWeight="SemiBold" FontSize="14"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock Text="{res:Loc Dashboard_UpdateAvailableDescription}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <TextBlock Text="{res:Loc Dashboard_Title}"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,24" />

            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc Dashboard_CloudProvider}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="ProviderStatus"
                                   Text="{res:Loc Dashboard_NotConfigured}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon x:Name="ProviderIcon" Symbol="Cloud24" FontSize="24" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc Dashboard_SteamInstallation}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="SteamStatus"
                                   Text="{res:Loc Dashboard_Detecting}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon Symbol="Desktop24" FontSize="24" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc Dashboard_AppsSyncing}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="AppCount"
                                   Text="{res:Loc Dashboard_AppCountDefault}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon Symbol="Apps24" FontSize="24" />
            </ui:CardControl>

            <ui:CardControl Margin="0,0,0,12">
                <ui:CardControl.Header>
                    <StackPanel>
                        <TextBlock Text="{res:Loc Dashboard_CloudRedirectDll}" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                        <TextBlock x:Name="DllStatus"
                                   Text="{res:Loc Dashboard_DllChecking}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </ui:CardControl.Header>
                <ui:SymbolIcon x:Name="DllIcon" Symbol="PlugConnected24" FontSize="24" />
            </ui:CardControl>

            <TextBlock Text="{res:Loc Dashboard_QuickActions}"
                       FontSize="20" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,24,0,12" />

            <WrapPanel>
                <ui:Button Content="Abrir log UI (cr_ui.log)"
                           Icon="{ui:SymbolIcon DocumentBulletList24}"
                           Appearance="Secondary"
                           Click="OpenUiLog_Click"
                           Margin="0,0,8,0" />
                <ui:Button Content="{res:Loc Dashboard_OpenLogFile}"
                           Icon="{ui:SymbolIcon Document24}"
                           Margin="0,0,8,8"
                           Click="OpenLog_Click" />
                <ui:Button Content="{res:Loc Dashboard_RestartSteam}"
                           Icon="{ui:SymbolIcon ArrowSync24}"
                           Margin="0,0,8,8"
                           Click="RestartSteam_Click" />
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
