<Page x:Class="ToolsCloud.Pages.SaveHistoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:res="clr-namespace:ToolsCloud.Resources"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel>

            <TextBlock Text="Histórico de Saves"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,8" />

            <TextBlock Text="Registro de todas as alterações feitas nos saves — importações, restaurações e exclusões."
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,0,0,16" />

            <WrapPanel Margin="0,0,0,16">
                <ui:TextBox x:Name="SearchBox"
                            PlaceholderText="Buscar por jogo ou evento..."
                            Width="280"
                            TextChanged="SearchBox_TextChanged"
                            Margin="0,0,8,0" />
                <ComboBox x:Name="FilterType"
                          Width="180"
                          SelectionChanged="FilterType_SelectionChanged"
                          Margin="0,0,8,0">
                    <ComboBoxItem Content="Todos os eventos" IsSelected="True" />
                    <ComboBoxItem Content="Importações Hydra" />
                    <ComboBoxItem Content="Importações Ludusavi" />
                    <ComboBoxItem Content="Saves (Criado/Atualizado)" />
                    <ComboBoxItem Content="Fusões" />
                    <ComboBoxItem Content="Restaurações" />
                    <ComboBoxItem Content="Deletados" />
                    <ComboBoxItem Content="Conquistas/Estatísticas" />
                </ComboBox>
                <ui:Button Content="Limpar histórico"
                           Icon="{ui:SymbolIcon Delete24}"
                           Appearance="Secondary"
                           Click="ClearHistory_Click" />
            </WrapPanel>

            <TextBlock x:Name="EmptyText"
                       Text="Nenhum evento registrado ainda. Os eventos aparecerão aqui conforme você importa, restaura ou modifica saves."
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                       FontSize="14"
                       Margin="0,24,0,0"
                       Visibility="Collapsed" />

            <ItemsControl x:Name="HistoryList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ui:CardControl Margin="0,0,0,8">
                            <ui:CardControl.Header>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Event type badge -->
                                    <Border Grid.Column="0"
                                            Width="10"
                                            CornerRadius="5"
                                            Background="{Binding BadgeColor}"
                                            Margin="0,0,14,0"
                                            VerticalAlignment="Stretch" />

                                    <!-- Info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding EventLabel}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                                       Margin="0,0,10,0" />
                                            <Border Padding="6,1" CornerRadius="4"
                                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                                                    BorderThickness="1">
                                                <TextBlock Text="{Binding GameName}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                            </Border>
                                        </StackPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <TextBlock Text="{Binding FormattedTime}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                       Margin="0,0,16,0" />
                                            <TextBlock Text="{Binding FileCount, StringFormat='{}{0} arquivo(s)'}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,0,16,0" />
                                            <TextBlock Text="{Binding FormattedSize}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       Margin="0,0,16,0" />
                                            <TextBlock Text="{Binding Detail}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxWidth="400" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <!-- AppId chip -->
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding AppId}"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0" />
                                </Grid>
                            </ui:CardControl.Header>
                        </ui:CardControl>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>
