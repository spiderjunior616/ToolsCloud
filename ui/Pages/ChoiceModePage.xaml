<Page x:Class="ToolsCloud.Pages.ChoiceModePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:res="clr-namespace:ToolsCloud.Resources"
      ScrollViewer.CanContentScroll="False">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
        <StackPanel MaxWidth="800">
            <TextBlock Text="{res:Loc Choice_Title}"
                       FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                       Margin="0,0,0,4" />
            <TextBlock Text="{res:Loc Choice_Description}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,24" />

            <!-- Current mode status (shown when mode already set) -->
            <Border x:Name="CurrentModeBanner"
                    Visibility="Collapsed"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,24">
                <StackPanel>
                    <TextBlock x:Name="CurrentModeText"
                               FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                    <TextBlock x:Name="CurrentModeDescription"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Margin="0,4,0,0" />
                </StackPanel>
            </Border>

            <!-- STFixer Mode card -->
            <Border x:Name="STFixerCard"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,16"
                    Cursor="Hand"
                    MouseLeftButtonUp="STFixerCard_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Symbol="Shield24" FontSize="36"
                                   Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                   VerticalAlignment="Top"
                                   Margin="0,0,16,0" />

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{res:Loc Choice_STFixer_Title}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{res:Loc Choice_STFixer_Description}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{res:Loc Choice_STFixer_Features}"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Cloud Redirect Mode card -->
            <Border x:Name="CloudRedirectCard"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="24"
                    Margin="0,0,0,16"
                    Cursor="Hand"
                    MouseLeftButtonUp="CloudRedirectCard_Click">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <ui:SymbolIcon Symbol="CloudArrowUp24" FontSize="36"
                                   Foreground="#CC2222"
                                   VerticalAlignment="Top"
                                   Margin="0,0,16,0" />

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="{res:Loc Choice_CloudRedirect_Title}"
                                   FontSize="18" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                   Margin="0,0,0,4" />
                        <TextBlock Text="{res:Loc Choice_CloudRedirect_Description}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <TextBlock Text="{res:Loc Choice_CloudRedirect_Features}"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                   TextWrapping="Wrap"
                                   FontSize="12" />
                    </StackPanel>
                </Grid>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
