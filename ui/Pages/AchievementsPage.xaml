<Page x:Class="ToolsCloud.Pages.AchievementsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:conv="clr-namespace:ToolsCloud.Converters"
      Title="Conquistas Sincronizadas"
      ScrollViewer.CanContentScroll="False">

    <Page.Resources>
        <conv:UrlToImageSourceConverter x:Key="UrlToImageSource" />
    </Page.Resources>

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                <TextBlock Text="Conquistas Sincronizadas" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" Margin="0,0,0,8" />
                <TextBlock Text="Veja os jogos que possuem dados de conquistas (Achievements) armazenados e sincronizados pelo CloudRedirect." Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="0,0,0,16"/>
                
                <!-- Dismissible banner: shown only when no API key is configured -->
                <Border x:Name="ApiKeyBanner" Visibility="Collapsed" Background="#1A2196F3" BorderBrush="#332196F3" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <ui:SymbolIcon Grid.Column="0" Symbol="Key24" FontSize="28" Foreground="#2196F3" VerticalAlignment="Center" Margin="0,0,12,0" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="Chave de API Steam não configurada" FontWeight="SemiBold" FontSize="14" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                            <TextBlock Text="Para traduzir os nomes das conquistas, configure sua Steam Web API Key em Configurações." FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>

                        <ui:Button Grid.Column="2" Content="Ir para Configurações" Icon="{ui:SymbolIcon Settings24}" Appearance="Primary" Click="GoToSettings_Click" VerticalAlignment="Center" Margin="8,0,0,0" />

                        <ui:Button Grid.Column="3" Appearance="Transparent" Icon="{ui:SymbolIcon Dismiss24}" Click="DismissBanner_Click" VerticalAlignment="Center" Margin="4,0,0,0" ToolTip="Fechar aviso" />
                    </Grid>
                </Border>
                
                <WrapPanel Margin="0,0,0,16">
                    <ui:Button Content="Atualizar Lista" Click="Refresh_Click" Icon="{ui:SymbolIcon ArrowClockwise24}" Margin="0,0,8,0" />
                    <ui:TextBox x:Name="SearchBox" PlaceholderText="Buscar jogos..." Width="250" TextChanged="SearchBox_TextChanged" Margin="0,0,8,0" />
                    <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="8,0,0,0"/>
                </WrapPanel>
                
                <ItemsControl x:Name="GamesList" Margin="0,0,0,20">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <ui:CardAction Margin="0,0,0,8" Padding="12" Click="GameCard_Click">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="92" Height="43" CornerRadius="4" Margin="0,0,12,0" VerticalAlignment="Center" ClipToBounds="True">
                                        <Border.Background>
                                            <ImageBrush ImageSource="{Binding HeaderUrl, Converter={StaticResource UrlToImageSource}}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality" />
                                        </Border.Background>
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding GameName}" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextFillColorPrimaryBrush}" TextTrimming="CharacterEllipsis" />
                                        <WrapPanel Margin="0,3,0,0">
                                            <TextBlock Text="{Binding AppId}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding Summary}" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                        </WrapPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{Binding UnlockedCount}" FontSize="20" FontWeight="Bold" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ui:SymbolIcon Grid.Column="3" Symbol="Trophy24" FontSize="24" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,12,0" />
                                </Grid>
                            </ui:CardAction>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Overlay Modal -->
        <Grid x:Name="ModalOverlay" Visibility="Collapsed" Background="#B2000000">
            <Border Background="{DynamicResource ApplicationBackgroundBrush}" CornerRadius="8" Margin="40" MaxWidth="800" VerticalAlignment="Center" BorderBrush="#33FFFFFF" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <ui:Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Icon="{ui:SymbolIcon Dismiss24}" Appearance="Transparent" Click="CloseModal_Click" />
                    
                    <StackPanel Grid.Row="0" Margin="24,24,24,12">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <ui:SymbolIcon Symbol="XboxController24" FontSize="28" Margin="0,0,12,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}"/>
                            <TextBlock x:Name="ModalGameName" FontSize="24" FontWeight="Bold" VerticalAlignment="Center" />
                        </StackPanel>
                        <TextBlock x:Name="ModalProgressText" Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="14" Margin="0,0,0,4" />
                        <ProgressBar x:Name="ModalProgressBar" Height="6" Maximum="100" Value="100" Foreground="#FF00CC6A" />
                    </StackPanel>
                    
                    <ListBox x:Name="ModalAchievementsList" Grid.Row="2" Margin="12,0,12,24" Background="Transparent" BorderThickness="0" MaxHeight="500" ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="12,0,12,8" Padding="12" Background="#1AFFFFFF" CornerRadius="8" BorderBrush="#33FFFFFF" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Grid.Column="0" Width="64" Height="64">
                                            <Border Background="#33000000" CornerRadius="4">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IconUrl}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <ui:SymbolIcon Symbol="Trophy24" FontSize="32" Foreground="#55FFFFFF" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>

                                            <Image Source="{Binding IconUrl}" Stretch="UniformToFill">
                                                <Image.Style>
                                                    <Style TargetType="Image">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IconUrl}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IconUrl}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Image.Style>
                                            </Image>
                                        </Grid>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <ui:SymbolIcon Symbol="CloudCheckmark24" Foreground="#FF00CC6A" Margin="0,0,8,0" FontSize="18" ToolTip="Sincronizado na Nuvem" />
                                                <TextBlock Text="{Binding DisplayText}" FontSize="16" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Description}" FontSize="13" Foreground="{DynamicResource TextFillColorSecondaryBrush}" TextWrapping="Wrap" Margin="26,0,0,0">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Description}" Value="{x:Null}">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Description}" Value="">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
